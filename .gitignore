# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ===== 测试 / 静态分析缓存 =====
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/

# ===== 打包 / 构建产物 =====
build/
dist/
*.egg-info/
*.spec.bak
*.app/

# ===== 独立资源（大文件不进 Git，通过网盘/手动同步） =====
assets/fonts/
assets/logos/
!assets/README.md
!assets/.gitkeep

# ===== Web 前端 =====
apps/web/node_modules/
apps/web/dist/
apps/web/*.tsbuildinfo
apps/web/vite.config.js
apps/web/vite.config.d.ts
apps/web/public/fonts/

# ===== 虚拟环境 =====
.venv/
venv/
env/

# ===== IDE / 编辑器 =====
.idea/
.vscode/
*.swp
*.swo

# ===== 系统垃圾 =====
.DS_Store
Thumbs.db

# ===== 项目运行时 =====
release/
input/
output/
logs/
tmp/
exiftool
exiftool.exe

# ===== 隐私内容（用户私有数据，不入库） =====
# 用户签名图（个人手写签名，敏感）
packages/kari-core/config/signatures/*
!packages/kari-core/config/signatures/.gitkeep
# 用户自定义 logo（个人版权 / 商标内容）
packages/kari-core/config/logos/custom/*
!packages/kari-core/config/logos/custom/.gitkeep
# 用户自定义模板与预设
packages/kari-core/config/presets/*
!packages/kari-core/config/presets/.gitkeep
packages/kari-core/config/templates/*.json
!packages/kari-core/config/templates/.gitkeep

# ===== 旧路径兜底（历史遗留） =====
logos/logo_psds
